#!/usr/bin/env python3
"""The `lore` CLI — vault scaffolding and section/status edit primitives.

Subcommands:
  lore init <path>          Scaffold a new vault (taxonomy + starter docs).
  lore new <type>           Render a template and write a new vault note.
  lore patch <file> <sec>   Append text under a section (--text or stdin).
  lore set-status <f> <v>   Validate + set a note's frontmatter status.
  lore stats                Print counts for the resolved vault.
  lore finish               Finalize the active session note for this worktree.
  lore handoff              Shelve the active session note for pickup later.
  lore shelved              List shelved/handoff session notes for pickup.
  lore resume <note|slug>   Flip a shelved/handoff note back to active.
  lore sync                 Stage, commit, and push the vault.
  lore review               Generate a vault migration-discipline report.

Finds its sibling ../scripts modules at import time so it works whether run
from the repo or from an installed plugin (${CLAUDE_PLUGIN_ROOT}/cli/lore).
"""
from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import os
import re
import shutil
import subprocess
import sys
from datetime import date
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "scripts"))

import frontmatter  # noqa: E402
import review as review_mod  # noqa: E402
import sessions as sessions_mod  # noqa: E402
import status_validator  # noqa: E402
import vault as vault_mod  # noqa: E402

PLUGIN_ROOT = Path(__file__).resolve().parent.parent
STARTER_DIR = PLUGIN_ROOT / "starter"
TEMPLATES_DIR = PLUGIN_ROOT / "templates"

# The generic directory taxonomy every vault gets.
TAXONOMY = [
    "sessions", "deferred", "subsystems", "decisions", "dead-ends", "lessons",
    "radar", "collaboration", "specs", "plans", "designs", "inbox",
    "briefings", "reviews", "gotchas", "audits", "tools", "templates",
]

STARTER_DOCS = ["README.md", "glossary.md", "phases.md", "harvest-protocol.md"]


# ---- new --------------------------------------------------------------------

# Map each note type to its vault directory.
_NOTE_DIRS: dict[str, str] = {
    "deferred": "deferred",
    "dead-end": "dead-ends",
    "decision": "decisions",
    "radar": "radar",
    "subsystem": "subsystems",
}

# Types that carry a project: field. dead-end is intentionally absent.
_PROJECT_BEARING: frozenset[str] = frozenset({"deferred", "decision", "radar", "subsystem"})

# Which section of the session note gets the backlink (None = no backlink).
_BACKLINK_SECTIONS: dict[str, str | None] = {
    "deferred": "Deferred",
    "dead-end": "Learned",
    "decision": "Decided",
    "radar": None,
    "subsystem": None,
}


def _kebab(title: str) -> str:
    """Lowercase, replace non-alphanumerics with a single hyphen, trim.

    When the result is empty (all-punctuation, whitespace, or non-Latin
    unicode), falls back to 'note-<first 6 hex chars of sha1(title)>' so the
    slug is always non-empty.
    """
    lowered = title.lower()
    slugged = re.sub(r"[^a-z0-9]+", "-", lowered)
    slug = slugged.strip("-")
    if not slug:
        digest = hashlib.sha1(title.encode()).hexdigest()[:6]
        slug = f"note-{digest}"
    return slug


def _unique_path(directory: Path, stem: str) -> Path:
    """Return a path in directory for <stem>.md that does not exist.

    If <stem>.md is free, return it. Otherwise append -2, -3, … until the
    path is free. Never overwrites an existing file.
    """
    candidate = directory / f"{stem}.md"
    if not candidate.exists():
        return candidate
    counter = 2
    while True:
        candidate = directory / f"{stem}-{counter}.md"
        if not candidate.exists():
            return candidate
        counter += 1


def _today() -> str:
    """Return today's date as YYYY-MM-DD, honoring $LORE_TODAY for tests."""
    override = os.environ.get("LORE_TODAY", "").strip()
    if override:
        return override
    return date.today().isoformat()


def _render_template(template_path: Path, substitutions: dict[str, str]) -> str:
    """Replace {{key}} placeholders in the template with provided values."""
    text = template_path.read_text()
    for key, value in substitutions.items():
        text = text.replace("{{" + key + "}}", value)
    return text


def _csv_to_inline_list(csv: str | None) -> str:
    """Convert a comma-separated string to an inline YAML list string.

    'a, b, c' → '[a, b, c]'
    None or empty → '[]'
    """
    if not csv:
        return "[]"
    items = [k.strip() for k in csv.split(",") if k.strip()]
    if not items:
        return "[]"
    return "[" + ", ".join(items) + "]"


def cmd_new(args: argparse.Namespace) -> int:
    note_type = args.type
    if note_type not in _NOTE_DIRS:
        print(
            f"error: unknown note type {note_type!r}. "
            f"Choose from: {', '.join(sorted(_NOTE_DIRS))}",
            file=sys.stderr,
        )
        return 1

    vault = Path(args.vault).expanduser().resolve() if args.vault else Path(vault_mod.resolve_vault())
    today = _today()
    user = vault_mod.resolve_user()

    # Resolve project: explicit flag wins; for project-bearing types fall back
    # to git remote inference; dead-end carries no project field at all.
    if note_type in _PROJECT_BEARING:
        project = args.project or vault_mod.resolve_project()
    else:
        project = args.project or ""

    # Build template substitutions — common fields.
    subs: dict[str, str] = {
        "date": today,
        "user": user,
        "project": project,
        "name": args.title,
    }

    # Per-type substitutions: populate frontmatter fields from CLI flags.
    if note_type == "deferred":
        subs["surfaces"] = _csv_to_inline_list(getattr(args, "surfaces", None))
        subs["next-check"] = getattr(args, "next_check", None) or ""
        revisit_after = getattr(args, "revisit_after", None) or ""
        subs["revisit-after"] = revisit_after
        # status: scheduled when revisit-after is provided, open otherwise.
        subs["status"] = "scheduled" if revisit_after else "open"

    elif note_type == "dead-end":
        subs["subsystems"] = _csv_to_inline_list(getattr(args, "subsystems", None))
        subs["tried"] = getattr(args, "tried", None) or today
        subs["revive-condition"] = getattr(args, "revive_condition", None) or ""

    elif note_type == "decision":
        subs["subsystems"] = _csv_to_inline_list(getattr(args, "subsystems", None))

    elif note_type == "radar":
        subs["source"] = getattr(args, "source", None) or ""
        subs["target"] = getattr(args, "target", None) or ""
        subs["check"] = getattr(args, "check", None) or ""

    elif note_type == "subsystem":
        subs["keywords"] = _csv_to_inline_list(getattr(args, "keywords", None))
        subs["key-files"] = _csv_to_inline_list(getattr(args, "key_files", None))

    template_path = TEMPLATES_DIR / f"{note_type}.md"
    if not template_path.is_file():
        print(f"error: template not found: {template_path}", file=sys.stderr)
        return 1

    rendered = _render_template(template_path, subs)

    # Validate status if the note type has one.
    fm = frontmatter.parse_frontmatter_str(rendered)
    note_status = fm.get("status")
    if note_status is not None:
        if not status_validator.is_valid_status(note_type, note_status):
            permitted = status_validator.permitted_statuses(note_type)
            print(
                f"error: template status {note_status!r} is not canonical for "
                f"type {note_type!r}. permitted: {sorted(permitted) if permitted else '(unconstrained)'}",
                file=sys.stderr,
            )
            return 1

    # Write the note — subsystem profiles are singletons identified by their
    # bare kebab name (no date prefix). All other types get YYYY-MM-DD-<slug>
    # naming with collision handling.
    note_dir = vault / _NOTE_DIRS[note_type]
    note_dir.mkdir(parents=True, exist_ok=True)
    if note_type == "subsystem":
        stem = _kebab(args.title)
        note_path = note_dir / f"{stem}.md"
        if note_path.exists():
            print(
                f"error: subsystem profile '{stem}' already exists at {note_path} — "
                "edit it directly (lore new subsystem creates a new profile).",
                file=sys.stderr,
            )
            return 1
    else:
        stem = f"{today}-{_kebab(args.title)}"
        note_path = _unique_path(note_dir, stem)
    note_path.write_text(rendered)
    print(f"Created: {note_path}")

    # Backlink to session note (deferred/dead-end/decision only).
    section = _BACKLINK_SECTIONS[note_type]
    if section is not None:
        worktree_name = Path.cwd().name
        session_note = vault_mod.find_session_note(vault, worktree_name=worktree_name)
        if session_note is None:
            print(
                f"note: no active session note found — backlink to {section!r} skipped.",
                file=sys.stderr,
            )
        else:
            rel_dir = _NOTE_DIRS[note_type]
            note_stem = note_path.stem  # includes any -2/-3 suffix
            title_display = args.title
            backlink = f"- [[{rel_dir}/{note_stem}]] — {title_display}"
            frontmatter.patch_section(session_note, section, backlink)

    return 0


# ---- init -------------------------------------------------------------------

def _is_under_home(target: Path) -> bool:
    home = Path.home().resolve()
    try:
        target.relative_to(home)
        return True
    except ValueError:
        return False


def _planned_tree(target: Path) -> str:
    lines = [f"{target}/"]
    for d in TAXONOMY:
        lines.append(f"  {d}/")
    lines.append("  .templates/")
    for doc in STARTER_DOCS:
        lines.append(f"  {doc}")
    lines.append("  harvest-pending.md")
    return "\n".join(lines)


def cmd_init(args: argparse.Namespace) -> int:
    target = Path(args.path).expanduser().resolve()

    if not _is_under_home(target) and not args.allow_outside_home:
        print(
            f"error: refusing to init outside $HOME: {target}\n"
            "pass --allow-outside-home to override.",
            file=sys.stderr,
        )
        return 1

    if target.exists() and any(target.iterdir()) and not args.force:
        print(
            f"error: refusing to init a non-empty directory: {target}\n"
            "pass --force to scaffold into it anyway (existing files are kept).",
            file=sys.stderr,
        )
        return 1

    print("Planned vault layout:")
    print(_planned_tree(target))
    print()

    if not args.yes:
        try:
            answer = input(f"Create this vault at {target}? [y/N] ").strip().lower()
        except EOFError:
            answer = ""
        if answer not in ("y", "yes"):
            print("Aborted; nothing written.", file=sys.stderr)
            return 1

    # Scaffold.
    target.mkdir(parents=True, exist_ok=True)
    for d in TAXONOMY:
        (target / d).mkdir(exist_ok=True)

    templates_out = target / ".templates"
    templates_out.mkdir(exist_ok=True)
    if TEMPLATES_DIR.is_dir():
        for item in sorted(TEMPLATES_DIR.iterdir()):
            if item.name == ".gitkeep":
                continue
            dest = templates_out / item.name
            if item.is_dir():
                shutil.copytree(item, dest, dirs_exist_ok=True)
            else:
                shutil.copy2(item, dest)

    for doc in STARTER_DOCS:
        src = STARTER_DIR / doc
        (target / doc).write_text(src.read_text())

    (target / "harvest-pending.md").write_text(
        "# Harvest pending\n\n"
        "Staging area for harvest candidates emitted by subagents. The session "
        "wrap-up ritual reads and clears this file.\n"
    )

    # Git-init the vault if it isn't already a git repo.
    git_dir = target / ".git"
    if not git_dir.is_dir():
        result = subprocess.run(
            ["git", "init", str(target)],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            print(f"warning: git init failed: {result.stderr.strip()}", file=sys.stderr)
        else:
            print(f"Initialized git repo at {target}")

    # Install the pre-commit status guard.
    installer = PLUGIN_ROOT / "hooks" / "install-vault-hooks.sh"
    if installer.is_file():
        env = dict(os.environ)
        env["LORE_PLUGIN_ROOT"] = str(PLUGIN_ROOT)
        result = subprocess.run(
            ["bash", str(installer), str(target)],
            capture_output=True, text=True, env=env,
        )
        if result.returncode != 0:
            print(f"warning: guard install failed: {result.stderr.strip()}", file=sys.stderr)
        else:
            print(result.stdout.strip())

    print(f"\nInitialized lore vault at {target}\n")
    print(f"export LORE_VAULT={target}")
    print(
        "Add that line to your shell profile. Without LORE_VAULT set, lore "
        "uses the default ~/lore instead of this vault."
    )
    return 0


# ---- patch ------------------------------------------------------------------

def cmd_patch(args: argparse.Namespace) -> int:
    path = Path(args.file).expanduser()
    if not path.is_file():
        print(f"error: no such file: {path}", file=sys.stderr)
        return 1
    text = args.text if args.text is not None else sys.stdin.read()
    if text == "":
        print("error: no text to append (pass --text or pipe via stdin)", file=sys.stderr)
        return 1
    frontmatter.patch_section(path, args.section, text)
    return 0


# ---- set-status -------------------------------------------------------------

def cmd_set_status(args: argparse.Namespace) -> int:
    path = Path(args.file).expanduser()
    if not path.is_file():
        print(f"error: no such file: {path}", file=sys.stderr)
        return 1
    meta = frontmatter.parse_frontmatter(path)
    note_type = meta.get("type")
    if not status_validator.is_valid_status(note_type, args.value):
        permitted = status_validator.permitted_statuses(note_type)
        permitted_str = sorted(permitted) if permitted else "(unconstrained)"
        print(
            f"error: status {args.value!r} is not canonical for type {note_type!r}\n"
            f"  permitted: {permitted_str}",
            file=sys.stderr,
        )
        return 1
    if not frontmatter.set_status(path, args.value):
        print(f"error: {path} has no frontmatter block", file=sys.stderr)
        return 1
    return 0


# ---- sync -------------------------------------------------------------------

DEFAULT_SYNC_MSG = "lore: sync vault"


def _git(vault: Path, *args: str) -> tuple[int, str, str]:
    """Run a git command in the vault. Returns (returncode, stdout, stderr)."""
    try:
        result = subprocess.run(
            ["git", "-C", str(vault), *args],
            capture_output=True, text=True, timeout=60,
        )
        return result.returncode, (result.stdout or "").strip(), (result.stderr or "").strip()
    except Exception as e:
        return 1, "", f"{type(e).__name__}: {e}"


def _vault_is_git_toplevel(vault: Path) -> bool:
    rc, out, _ = _git(vault, "rev-parse", "--show-toplevel")
    if rc != 0 or not out:
        return False
    try:
        return Path(out).resolve() == vault.resolve()
    except Exception:
        return False


def cmd_sync(args: argparse.Namespace) -> int:
    vault = Path(vault_mod.resolve_vault())

    if not vault.exists():
        print(f"error: vault not found: {vault}", file=sys.stderr)
        return 1

    if not _vault_is_git_toplevel(vault):
        print(
            f"error: vault is not its own git toplevel: {vault}\n"
            "  (vault may be a subdirectory of a larger repo, or not a git repo)\n"
            "  Aborting — refusing to operate on the wrong tree.",
            file=sys.stderr,
        )
        return 1

    message = getattr(args, "message", None) or DEFAULT_SYNC_MSG

    # Stage everything.
    rc, _, stderr = _git(vault, "add", "-A")
    if rc != 0:
        print(f"error: git add failed: {stderr}", file=sys.stderr)
        return 1

    # Check if there's anything to commit.
    rc, status_out, _ = _git(vault, "status", "--porcelain")
    if rc != 0 or not status_out.strip():
        print("Nothing to commit — vault is clean.")
        return 0

    # Commit — never pass -S or --no-gpg-sign; honor adopter's commit.gpgsign.
    rc, _, stderr = _git(vault, "commit", "-m", message)
    if rc != 0:
        print(f"error: git commit failed: {stderr}", file=sys.stderr)
        return 1
    print(f"Committed: {message}")

    # Push to origin if it exists.
    rc_remote, remote_url, _ = _git(vault, "remote", "get-url", "origin")
    if rc_remote != 0 or not remote_url:
        print("No origin remote — skipping push.")
        return 0

    rc_push, _, stderr_push = _git(vault, "push", "origin")
    if rc_push != 0:
        print(
            f"notice: committed locally; push failed — re-run `lore sync` when online",
            file=sys.stderr,
        )
        print(f"  push error: {stderr_push}", file=sys.stderr)
        return 0
    print("Pushed to origin.")
    return 0


# ---- finish -----------------------------------------------------------------

def _get_current_status(note: Path) -> str | None:
    """Return the current status value from a note's frontmatter, or None."""
    try:
        fm = frontmatter.parse_frontmatter(note)
        status = fm.get("status")
        return str(status) if status is not None else None
    except Exception:
        return None


def _commit_and_push_session_note(vault: Path, session_note: Path, worktree_name: str, verb: str) -> int:
    """Stage, commit, and push a single session note. Returns exit code."""
    if not vault.exists():
        print(f"notice: vault not found: {vault} — skipping commit.", file=sys.stderr)
        return 0

    if not _vault_is_git_toplevel(vault):
        print(
            "notice: vault is not its own git toplevel — skipping commit.",
            file=sys.stderr,
        )
        return 0

    rc, _, stderr = _git(vault, "add", "--", str(session_note))
    if rc != 0:
        print(f"error: git add failed: {stderr}", file=sys.stderr)
        return 1

    rc, status_out, _ = _git(vault, "status", "--porcelain")
    if rc != 0 or not status_out.strip():
        print("Nothing to commit — vault is clean.")
        return 0

    message = f"session: {verb} {worktree_name}"
    rc, _, stderr = _git(vault, "commit", "-m", message)
    if rc != 0:
        print(f"error: git commit failed: {stderr}", file=sys.stderr)
        return 1
    print(f"Committed: {message}")

    rc_remote, remote_url, _ = _git(vault, "remote", "get-url", "origin")
    if rc_remote != 0 or not remote_url:
        print("No origin remote — skipping push.")
        return 0

    rc_push, _, stderr_push = _git(vault, "push", "origin")
    if rc_push != 0:
        print(
            "notice: committed locally; push failed — re-run `lore sync` when online",
            file=sys.stderr,
        )
        print(f"  push error: {stderr_push}", file=sys.stderr)
        return 0
    print("Pushed to origin.")
    return 0


def cmd_finish(args: argparse.Namespace) -> int:
    """Finalize the active session note for the current worktree.

    Finds the session note via `vault.find_session_note()` scoped to this
    worktree (cwd name), sets `status: complete` and `ended:` to the current
    UTC timestamp (atomic write), then runs the same commit path as `lore sync`.
    If no active session note is found, prints a notice and exits 0.
    """
    vault = Path(vault_mod.resolve_vault())
    worktree_name = Path.cwd().name

    session_note = vault_mod.find_session_note(vault, worktree_name=worktree_name)
    if session_note is None:
        print(
            f"notice: no active session note found for worktree {worktree_name!r} — "
            "nothing to finalize.",
        )
        return 0

    now_iso = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    ok = sessions_mod.finalize_note(session_note, now_iso)
    if not ok:
        current_status = _get_current_status(session_note)
        label = current_status if current_status else "terminal"
        print(f"notice: already {label} — nothing to finalize.")
        return 0
    print(f"Finalized: {session_note.name}")
    return _commit_and_push_session_note(vault, session_note, worktree_name, "finalize")


# ---- handoff ----------------------------------------------------------------

def cmd_handoff(args: argparse.Namespace) -> int:
    """Shelve the active session note for the current worktree.

    Mirrors `lore finish` but writes ``status: shelved`` instead of
    ``status: complete``.  Idempotent: when the note is already in a
    terminal status, prints a notice and returns 0 without committing.

    When ``--pickup-hints-file`` is given, the file's content is written
    under a ``## Pickup hints`` section of the session note BEFORE shelving
    (atomic: hints + shelve happen together, never hints-only).  If the note
    is already terminal, the idempotency guard fires BEFORE writing hints so
    an already-shelved note is never double-written.
    """
    vault = Path(vault_mod.resolve_vault())
    worktree_name = Path.cwd().name

    session_note = vault_mod.find_session_note(vault, worktree_name=worktree_name)
    if session_note is None:
        print(
            f"notice: no active session note found for worktree {worktree_name!r} — "
            "nothing to shelve.",
        )
        return 0

    hints_file: Path | None = getattr(args, "pickup_hints_file", None)
    if hints_file is not None:
        hints_file = Path(hints_file)

    now_iso = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    ok = sessions_mod.finalize_note(session_note, now_iso, status="shelved")
    if not ok:
        current_status = _get_current_status(session_note)
        label = current_status if current_status else "terminal"
        print(f"notice: already {label} — nothing to do.")
        return 0

    if hints_file is not None:
        try:
            hints_text = hints_file.read_text()
        except Exception as exc:
            print(f"error: cannot read --pickup-hints-file {hints_file}: {exc}", file=sys.stderr)
            return 1
        frontmatter.patch_section(session_note, "Pickup hints", hints_text)

    print(f"Shelved: {session_note.name}")
    return _commit_and_push_session_note(vault, session_note, worktree_name, "shelve")


# ---- shelved / resume (pickup surface) --------------------------------------

def _pickup_hints_fragment(note: Path) -> str:
    """Return a one-line context fragment for a shelved note.

    Prefers the first non-empty line under a ``## Pickup hints`` heading; falls
    back to the note's ``# `` title line, then the filename stem. Truncated so a
    list stays scannable. Never raises.
    """
    try:
        text = note.read_text()
    except Exception:
        return note.stem

    lines = text.splitlines()
    in_hints = False
    for line in lines:
        if line.strip().lower().startswith("## pickup hints"):
            in_hints = True
            continue
        if in_hints:
            if line.strip().startswith("## "):
                break
            if line.strip():
                return line.strip()[:80]

    for line in lines:
        if line.startswith("# "):
            return line[2:].strip()[:80]
    return note.stem


def _note_timestamp(note: Path) -> str:
    """Return the note's ended:/started: frontmatter timestamp, or '(no timestamp)'."""
    try:
        fm = frontmatter.parse_frontmatter(note)
    except Exception:
        return "(no timestamp)"
    for key in ("ended", "started"):
        val = fm.get(key)
        if isinstance(val, str) and val.strip():
            return val.strip()
    return "(no timestamp)"


def cmd_shelved(args: argparse.Namespace) -> int:
    """List shelved/handoff session notes, most-recent-first.

    Prints each note's path + frontmatter timestamp + a short context fragment
    (first Pickup-hints line, else the title) so an interactive picker is
    usable. Optional ``--slug`` narrows to one worktree slug.
    """
    vault = Path(vault_mod.resolve_vault())
    slug = getattr(args, "slug", None)
    notes = sessions_mod.find_shelved_notes(vault, slug=slug)

    if not notes:
        if slug:
            print(f"Nothing shelved for slug {slug!r}.")
        else:
            print("Nothing shelved — no notes to resume.")
        return 0

    for note in notes:
        ts = _note_timestamp(note)
        fragment = _pickup_hints_fragment(note)
        print(f"{note}")
        print(f"  {ts} — {fragment}")
    return 0


def _resolve_resume_target(vault: Path, target: str) -> Path | None:
    """Resolve a resume target — an explicit file path OR a worktree slug.

    A path that exists is used directly. Otherwise *target* is treated as a
    slug and matched against shelved/handoff notes (most-recent-first). Returns
    None when nothing matches.
    """
    as_path = Path(target).expanduser()
    if as_path.is_file():
        return as_path
    matches = sessions_mod.find_shelved_notes(vault, slug=target)
    return matches[0] if matches else None


def cmd_resume(args: argparse.Namespace) -> int:
    """Flip a shelved/handoff session note back to active.

    Accepts an explicit note path OR a worktree slug. On a non-resumable note
    (active/complete/finalized) prints a clear no-op message and returns 0.
    A target that resolves to nothing is an error (non-zero).
    """
    vault = Path(vault_mod.resolve_vault())
    note = _resolve_resume_target(vault, args.target)
    if note is None:
        print(f"error: no shelved note found for {args.target!r}", file=sys.stderr)
        return 1

    if sessions_mod.resume_note(note):
        print(f"Resumed: {note.name} (status: active)")
        return 0

    current = _get_current_status(note) or "unknown"
    print(f"notice: {note.name} is not shelved (status: {current}) — nothing to resume.")
    return 0


# ---- review -----------------------------------------------------------------

def cmd_review(args: argparse.Namespace) -> int:
    """Generate a vault migration-discipline report.

    Outputs a structured markdown report covering: git activity since the
    last review, action taxonomy drift, graduation candidates, stale subsystem
    profiles, open deferred items, dead-ends, open radar items, and active
    lessons. Read-only — the report never mutates the vault.
    """
    vault = Path(vault_mod.resolve_vault())

    if not vault.exists():
        print(f"error: vault not found: {vault}", file=sys.stderr)
        return 1

    since = review_mod.resolve_since(vault, getattr(args, "since", None))
    report = review_mod.build_report(vault, since)
    print(report)
    return 0


# ---- stats ------------------------------------------------------------------

def _count(directory: Path, predicate) -> int:
    if not directory.is_dir():
        return 0
    return sum(1 for p in directory.glob("*.md") if predicate(frontmatter.parse_frontmatter(p)))


def cmd_stats(args: argparse.Namespace) -> int:
    vault = Path(vault_mod.resolve_vault())
    subsystems = _count(vault / "subsystems", lambda fm: True)
    open_deferred = _count(
        vault / "deferred",
        lambda fm: fm.get("status") in ("open", "resurfaced"),
    )
    active_lessons = _count(
        vault / "lessons",
        lambda fm: fm.get("status", "active") == "active",
    )
    dead_ends = _count(vault / "dead-ends", lambda fm: fm.get("type") == "dead-end")
    sessions = _count(vault / "sessions", lambda fm: fm.get("type") == "session")

    print(f"vault: {vault}")
    print(f"subsystems:     {subsystems}")
    print(f"open deferred:  {open_deferred}")
    print(f"active lessons: {active_lessons}")
    print(f"dead-ends:      {dead_ends}")
    print(f"sessions:       {sessions}")
    return 0


# ---- argparse ---------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="lore", description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)

    p_init = sub.add_parser("init", help="Scaffold a new vault")
    p_init.add_argument("path")
    p_init.add_argument("--force", action="store_true", help="Scaffold into a non-empty dir")
    p_init.add_argument("--allow-outside-home", action="store_true", help="Allow a target outside $HOME")
    p_init.add_argument("--yes", action="store_true", help="Skip the confirmation prompt")
    p_init.set_defaults(func=cmd_init)

    p_patch = sub.add_parser("patch", help="Append text under a section")
    p_patch.add_argument("file")
    p_patch.add_argument("section")
    p_patch.add_argument("--text", default=None, help="Text to append (else read stdin)")
    p_patch.set_defaults(func=cmd_patch)

    p_status = sub.add_parser("set-status", help="Validate + set a note's status")
    p_status.add_argument("file")
    p_status.add_argument("value")
    p_status.set_defaults(func=cmd_set_status)

    p_stats = sub.add_parser("stats", help="Print counts for the resolved vault")
    p_stats.set_defaults(func=cmd_stats)

    p_sync = sub.add_parser("sync", help="Stage, commit, and push the vault")
    p_sync.add_argument(
        "--message", "-m", default=None,
        help=f"Commit message (default: {DEFAULT_SYNC_MSG!r})",
    )
    p_sync.set_defaults(func=cmd_sync)

    p_new = sub.add_parser("new", help="Render a template and write a new vault note")
    p_new.add_argument("type", choices=list(_NOTE_DIRS), help="Note type to create")
    p_new.add_argument("--title", required=True, help="Title for the note (used in slug)")
    p_new.add_argument("--vault", default=None, help="Vault path (overrides $LORE_VAULT)")
    p_new.add_argument("--project", default=None, help="Project name to stamp in frontmatter")
    # deferred
    p_new.add_argument("--surfaces", default=None, help="CSV subsystem names this item surfaces on (deferred)")
    p_new.add_argument("--next-check", dest="next_check", default=None, help="When to next check (deferred)")
    p_new.add_argument("--revisit-after", dest="revisit_after", default=None, help="Date-bound revisit trigger (deferred)")
    # dead-end
    p_new.add_argument("--subsystems", default=None, help="CSV subsystem names (dead-end, decision)")
    p_new.add_argument("--tried", default=None, help="Date the approach was tried (dead-end; defaults to today)")
    p_new.add_argument("--revive-condition", dest="revive_condition", default=None, help="Condition to retry (dead-end)")
    # radar
    p_new.add_argument("--source", default=None, help="Where updates appear (radar)")
    p_new.add_argument("--target", default=None, help="Version or state being waited for (radar)")
    p_new.add_argument("--check", default=None, help="Check cadence (radar)")
    # subsystem
    p_new.add_argument("--keywords", default=None, help="CSV keywords for branch-based recall (subsystem)")
    p_new.add_argument("--key-files", dest="key_files", default=None, help="CSV key file paths (subsystem)")
    p_new.set_defaults(func=cmd_new)

    p_finish = sub.add_parser(
        "finish",
        help="Finalize the active session note for this worktree",
    )
    p_finish.set_defaults(func=cmd_finish)

    p_handoff = sub.add_parser(
        "handoff",
        help="Shelve the active session note for this worktree (for pickup later)",
    )
    p_handoff.add_argument(
        "--pickup-hints-file",
        dest="pickup_hints_file",
        default=None,
        metavar="PATH",
        help="File whose content is written under '## Pickup hints' before shelving",
    )
    p_handoff.set_defaults(func=cmd_handoff)

    p_shelved = sub.add_parser(
        "shelved",
        help="List shelved/handoff session notes (most-recent-first) for pickup",
    )
    p_shelved.add_argument(
        "--slug",
        default=None,
        help="Narrow to one worktree slug",
    )
    p_shelved.set_defaults(func=cmd_shelved)

    p_resume = sub.add_parser(
        "resume",
        help="Flip a shelved/handoff session note back to active",
    )
    p_resume.add_argument(
        "target",
        help="Session note path OR worktree slug to resume",
    )
    p_resume.set_defaults(func=cmd_resume)

    p_review = sub.add_parser(
        "review",
        help="Generate a vault migration-discipline report",
    )
    p_review.add_argument(
        "--since",
        default=None,
        help="Lookback window for activity section (e.g. 7d, 2026-04-01). "
             "Default: since the most recent review note, or 7 days ago.",
    )
    p_review.set_defaults(func=cmd_review)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
