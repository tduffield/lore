def _get_current_status(note: Path) -> str | None:
    """Return the current status value from a note's frontmatter, or None."""
    try:
        fm = frontmatter.parse_frontmatter(note)
        status = fm.get("status")
        return str(status) if status is not None else None
    except Exception:
        return None


def _commit_and_push_session_note(vault: Path, session_note: Path, worktree_name: str, verb: str) -> int:
    """Stage, commit, and push a single session note. Returns exit code."""
    if not vault.exists():
        print(f"notice: vault not found: {vault} — skipping commit.", file=sys.stderr)
        return 0

    if not _vault_is_git_toplevel(vault):
        print(
            "notice: vault is not its own git toplevel — skipping commit.",
            file=sys.stderr,
        )
        return 0

    rc, _, stderr = _git(vault, "add", "--", str(session_note))
    if rc != 0:
        print(f"error: git add failed: {stderr}", file=sys.stderr)
        return 1

    rc, status_out, _ = _git(vault, "status", "--porcelain")
    if rc != 0 or not status_out.strip():
        print("Nothing to commit — vault is clean.")
        return 0

    message = f"session: {verb} {worktree_name}"
    rc, _, stderr = _git(vault, "commit", "-m", message)
    if rc != 0:
        print(f"error: git commit failed: {stderr}", file=sys.stderr)
        return 1
    print(f"Committed: {message}")

    rc_remote, remote_url, _ = _git(vault, "remote", "get-url", "origin")
    if rc_remote != 0 or not remote_url:
        print("No origin remote — skipping push.")
        return 0

    rc_push, _, stderr_push = _git(vault, "push", "origin")
    if rc_push != 0:
        print(
            "notice: committed locally; push failed — re-run `lore sync` when online",
            file=sys.stderr,
        )
        print(f"  push error: {stderr_push}", file=sys.stderr)
        return 0
    print("Pushed to origin.")
    return 0


def _harvest_expand(vault: Path, session_note: Path) -> harvest_mod.ExpansionResult | None:
    """Expand harvest-pending + the session note's candidates block to disk.

    Writes the expanded notes (idempotent by harvest-hash) but does NOT touch
    the pending file or git — the caller folds the pending rewrite into the
    same atomic commit. Returns None when there is no pending file to read.
    """
    pending = vault / "harvest-pending.md"
    pending_text = pending.read_text(encoding="utf-8") if pending.exists() else ""
    try:
        session_text = session_note.read_text(encoding="utf-8")
    except Exception:
        session_text = ""

    project = vault_mod.resolve_project()
    return harvest_mod.expand(
        vault=vault,
        pending_text=pending_text,
        session_text=session_text,
        templates_dir=TEMPLATES_DIR,
        today=_today(),
        project=project,
    )


def _report_harvest(result: harvest_mod.ExpansionResult) -> None:
    for path in result.written:
        print(f"Harvested: {path}")
    for warning in result.warnings:
        print(warning, file=sys.stderr)
    if result.gotchas:
        print("Surfaced gotchas (not expanded — patch via /lore:area):")
        for g in result.gotchas:
            print(f"  - gotcha: {g.body}")


def _finish_commit(
    vault: Path,
    session_note: Path,
    pending: Path,
    new_notes: list[Path],
    worktree_name: str,
) -> int:
    """Stage explicit paths + commit the session note, new notes, and pending
    in a SINGLE commit. Never `git add -A`. On commit failure the notes remain
    on disk and the (unrewritten) pending still holds the entries, so a re-run
    re-expands cleanly (dedup-by-hash). Returns exit code."""
    if not vault.exists() or not _vault_is_git_toplevel(vault):
        print("notice: vault is not its own git toplevel — skipping commit.", file=sys.stderr)
        return 0

    paths = [str(session_note)] + [str(p) for p in new_notes]
    if pending.exists():
        paths.append(str(pending))

    rc, _, stderr = _git(vault, "add", "--", *paths)
    if rc != 0:
        print(f"error: git add failed: {stderr}", file=sys.stderr)
        return 1

    rc, _, _ = _git(vault, "diff", "--cached", "--quiet")
    if rc == 0:
        print("Nothing to commit — index is clean.")
        return 0

    message = f"session: finalize {worktree_name}"
    rc, _, stderr = _git(vault, "commit", "-m", message)
    if rc != 0:
        print(f"error: git commit failed: {stderr}", file=sys.stderr)
        return 1
    print(f"Committed: {message}")

    rc_remote, remote_url, _ = _git(vault, "remote", "get-url", "origin")
    if rc_remote != 0 or not remote_url:
        print("No origin remote — skipping push.")
        return 0
    rc_push, _, stderr_push = _git(vault, "push", "origin")
    if rc_push != 0:
        print("notice: committed locally; push failed — re-run `lore sync` when online", file=sys.stderr)
        print(f"  push error: {stderr_push}", file=sys.stderr)
        return 0
    print("Pushed to origin.")
    return 0


def cmd_finish(args: argparse.Namespace) -> int:
    """Finalize the active session note for the current worktree.

    Resolves the session note via `vault.resolve_session_note()` — exact
    session-id match first (so the *current* session's note is finalized even
    when several exist for this worktree), then a worktree-name fallback. Sets
    `status: complete` and `ended:` (atomic write), then expands the in-scope
    harvest-pending entries + the note's `## Harvest candidates` block into full
    vault notes and commits the session note + new notes + the rewritten pending
    in ONE commit (explicit paths only). `gotcha` entries are surfaced (not
    expanded) and left in pending; malformed lines are retained + warned. On
    commit failure the notes are on disk and pending is restored, so a re-run
    re-expands idempotently. If no active session note is found, prints a notice
    and exits 0.
    """
    vault = Path(vault_mod.resolve_vault())
    session_id = _session_id_from_args_or_env(args)
    worktree_name = args.worktree or vault_mod.detect_worktree_name()

    session_note = vault_mod.resolve_session_note(
        vault, session_id=session_id, worktree_name=worktree_name
    )
    if session_note is None:
        print(
            f"notice: no active session note found for worktree {worktree_name!r} — "
            "nothing to finalize.",
        )
        return 0

    now_iso = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    ok = sessions_mod.finalize_note(session_note, now_iso)
    if ok:
        print(f"Finalized: {session_note.name}")
    else:
        # Already terminal. Still attempt harvest expansion: a prior finish may
        # have finalized the note but failed to commit the harvest (e.g. a
        # failed commit), leaving pending entries to recover. If there is no
        # pending work, the expansion + commit are both no-ops.
        current_status = _get_current_status(session_note)
        label = current_status if current_status else "terminal"
        print(f"notice: already {label} — checking for unharvested pending entries.")

    # Expand harvest entries to disk FIRST (notes survive a failed commit).
    result = _harvest_expand(vault, session_note)
    if result is not None:
        _report_harvest(result)

    if not _vault_is_git_toplevel(vault):
        # Non-git vault: status is set, notes are written, but no commit.
        print("notice: vault is not its own git toplevel — skipping commit.", file=sys.stderr)
        return 0

    # Rewrite pending to drop consumed entries — but ONLY as part of the same
    # commit. We write it to disk here, then stage+commit; if the commit fails,
    # the consumed entries were already cleared from the working tree, so we
    # restore the file on failure to keep the entries recoverable.
    pending = vault / "harvest-pending.md"
    pending_before = pending.read_text(encoding="utf-8") if pending.exists() else None
    if result is not None and result.consumed_hashes and pending_before is not None:
        pending.write_text(
            harvest_mod.rewrite_pending(pending_before, result.consumed_hashes),
            encoding="utf-8",
        )

    new_notes = result.written if result is not None else []
    rc = _finish_commit(vault, session_note, pending, new_notes, worktree_name)
    if rc != 0 and pending_before is not None:
        # Commit failed: restore pending so no entry is lost; notes stay on disk
        # and a clean re-run re-expands idempotently (dedup-by-hash).
        pending.write_text(pending_before, encoding="utf-8")
    return rc


# ---- handoff ----------------------------------------------------------------

def cmd_handoff(args: argparse.Namespace) -> int:
    """Shelve the active session note for the current worktree.

    Mirrors `lore finish` but writes ``status: shelved`` instead of
    ``status: complete``.  Idempotent: when the note is already in a
    terminal status, prints a notice and returns 0 without committing.

    When ``--pickup-hints-file`` is given, the file's content is written
    under a ``## Pickup hints`` section of the session note BEFORE shelving
    (atomic: hints + shelve happen together, never hints-only).  If the note
    is already terminal, the idempotency guard fires BEFORE writing hints so
    an already-shelved note is never double-written.

    Resolves the note via `vault.resolve_session_note()` (session-id first,
    worktree-name fallback) so the *current* session's note is shelved.
    """
    vault = Path(vault_mod.resolve_vault())
    session_id = _session_id_from_args_or_env(args)
    worktree_name = args.worktree or vault_mod.detect_worktree_name()

    session_note = vault_mod.resolve_session_note(
        vault, session_id=session_id, worktree_name=worktree_name
    )
    if session_note is None:
        print(
            f"notice: no active session note found for worktree {worktree_name!r} — "
            "nothing to shelve.",
        )
        return 0

    hints_file: Path | None = getattr(args, "pickup_hints_file", None)
    if hints_file is not None:
        hints_file = Path(hints_file)

    now_iso = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    ok = sessions_mod.finalize_note(session_note, now_iso, status="shelved")
    if not ok:
        current_status = _get_current_status(session_note)
        label = current_status if current_status else "terminal"
        print(f"notice: already {label} — nothing to do.")
        return 0

    if hints_file is not None:
        try:
            hints_text = hints_file.read_text()
        except Exception as exc:
            print(f"error: cannot read --pickup-hints-file {hints_file}: {exc}", file=sys.stderr)
            return 1
        frontmatter.patch_section(session_note, "Pickup hints", hints_text)

    print(f"Shelved: {session_note.name}")
    return _commit_and_push_session_note(vault, session_note, worktree_name, "shelve")


# ---- shelved / resume (pickup surface) --------------------------------------

def _pickup_hints_fragment(note: Path) -> str:
    """Return a one-line context fragment for a shelved note.

    Prefers the first non-empty line under a ``## Pickup hints`` heading; falls
    back to the note's ``# `` title line, then the filename stem. Truncated so a
    list stays scannable. Never raises.
    """
    try:
        text = note.read_text()
    except Exception:
        return note.stem

    lines = text.splitlines()
    in_hints = False
    for line in lines:
        if line.strip().lower().startswith("## pickup hints"):
            in_hints = True
            continue
        if in_hints:
            if line.strip().startswith("## "):
                break
            if line.strip():
                return line.strip()[:80]

    for line in lines:
        if line.startswith("# "):
            return line[2:].strip()[:80]
    return note.stem


def _note_timestamp(note: Path) -> str:
    """Return the note's ended:/started: frontmatter timestamp, or '(no timestamp)'."""
    try:
        fm = frontmatter.parse_frontmatter(note)
    except Exception:
        return "(no timestamp)"
    for key in ("ended", "started"):
        val = fm.get(key)
        if isinstance(val, str) and val.strip():
            return val.strip()
    return "(no timestamp)"


def cmd_shelved(args: argparse.Namespace) -> int:
    """List shelved/handoff session notes, most-recent-first.

    Prints each note's path + frontmatter timestamp + a short context fragment
    (first Pickup-hints line, else the title) so an interactive picker is
    usable. Optional ``--slug`` narrows to one worktree slug.
    """
    vault = Path(vault_mod.resolve_vault())
    slug = getattr(args, "slug", None)
    notes = sessions_mod.find_shelved_notes(vault, slug=slug)

    if not notes:
        if slug:
            print(f"Nothing shelved for slug {slug!r}.")
        else:
            print("Nothing shelved — no notes to resume.")
        return 0

    for note in notes:
        ts = _note_timestamp(note)
        fragment = _pickup_hints_fragment(note)
        print(f"{note}")
        print(f"  {ts} — {fragment}")
    return 0


def _resolve_resume_target(vault: Path, target: str) -> Path | None:
    """Resolve a resume target — an explicit file path OR a worktree slug.

    A path that exists is used directly. Otherwise *target* is treated as a
    slug and matched against shelved/handoff notes (most-recent-first). Returns
    None when nothing matches.
    """
    as_path = Path(target).expanduser()
    if as_path.is_file():
        return as_path
    matches = sessions_mod.find_shelved_notes(vault, slug=target)
    return matches[0] if matches else None


def _resolve_implicit_resume_target(vault: Path, args: argparse.Namespace) -> Path | None:
    """Resolve the resume target when no positional was given: exact
    session-id match (any status — `resume_note` rejects non-shelved notes),
    else the most-recent shelved note for the worktree (override or detected)."""
    session_id = _session_id_from_args_or_env(args)
    if session_id:
        return vault_mod.find_session_note_by_session_id(vault, session_id)
    worktree_name = args.worktree or vault_mod.detect_worktree_name()
    matches = sessions_mod.find_shelved_notes(vault, slug=worktree_name)
    return matches[0] if matches else None


def cmd_resume(args: argparse.Namespace) -> int:
    """Flip a shelved/handoff session note back to active.

    With a positional target, accepts an explicit note path OR a worktree slug.
    With no target, resolves the current session's shelved note (``--session-id``
    → ``--worktree`` → auto-detected worktree). On a non-resumable note
    (active/complete/finalized) prints a clear no-op message and returns 0.
    A target that resolves to nothing is an error (non-zero).
    """
    vault = Path(vault_mod.resolve_vault())
    if args.target:
        note = _resolve_resume_target(vault, args.target)
    else:
        note = _resolve_implicit_resume_target(vault, args)
    if note is None:
        label = args.target or args.worktree or _session_id_from_args_or_env(args) or "current worktree"
        print(f"error: no shelved note found for {label!r}", file=sys.stderr)
        return 1

    if sessions_mod.resume_note(note):
        print(f"Resumed: {note.name} (status: active)")
        return 0

    current = _get_current_status(note) or "unknown"
    print(f"notice: {note.name} is not shelved (status: {current}) — nothing to resume.")
    return 0


