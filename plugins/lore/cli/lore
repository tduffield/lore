# ---- validate ---------------------------------------------------------------

# Top-level path components that are not part of the vault note space.
_NON_NOTE_TOPS = {".claude", ".templates", ".pytest_cache", ".obsidian", ".git", "templates"}


def _iter_vault_notes(vault: Path):
    """Yield tracked note .md paths (relative strings) in the vault.

    Uses `git ls-files` when the vault is a git repo (covers every tracked
    note dir); falls back to a filesystem walk otherwise. Excludes non-note
    trees (.claude/, templates/, etc.) and `_`-prefixed files/dirs
    (_index.md, _daily/, _archive/, _test/). Files with no frontmatter block
    validate clean, so generated/data files cost nothing.
    """
    rc, out, _ = _git(vault, "ls-files", "-z", "*.md")
    if rc == 0 and out is not None:
        for rel in out.split("\0"):
            if not rel:
                continue
            parts = rel.split("/")
            if parts[0] in _NON_NOTE_TOPS:
                continue
            if any(p.startswith("_") for p in parts):
                continue
            yield rel
        return
    # Non-git fallback: walk note dirs.
    for top in sorted(vault.iterdir()):
        if not top.is_dir() or top.name in _NON_NOTE_TOPS or top.name.startswith("."):
            continue
        for p in top.rglob("*.md"):
            if any(part.startswith("_") for part in p.relative_to(vault).parts):
                continue
            yield str(p.relative_to(vault))


def cmd_validate(args: argparse.Namespace) -> int:
    """Validate vault frontmatter against the canonical schema.

    Reports notes missing required fields (type / group / per-type required)
    or carrying an invalid group, plus field-name drift warnings. With
    --strict, also reports unknown fields. Exits 1 when any error is found
    (warnings alone exit 0), so it doubles as a CI / pre-push check.
    """
    vault = Path(vault_mod.resolve_vault())
    if not vault.exists():
        print(f"error: vault not found: {vault}", file=sys.stderr)
        return 1

    strict = getattr(args, "strict", False)
    require_group, allowed_groups = fmschema_mod.group_config(vault)
    errors: list[str] = []
    warnings: list[str] = []
    checked = 0
    for rel in _iter_vault_notes(vault):
        checked += 1
        for issue in fmval_mod.validate_file(
            vault / rel, require_group=require_group,
            allowed_groups=allowed_groups, strict=strict,
        ):
            line = f"  {rel}: {issue.message}"
            (errors if issue.severity == fmval_mod.ERROR else warnings).append(line)

    if errors:
        print(f"Errors ({len(errors)}):")
        for e in errors:
            print(e)
        print()
    if warnings:
        print(f"Drift warnings ({len(warnings)}):")
        for w in warnings:
            print(w)
        print()

    status = "FAIL" if errors else "ok"
    print(f"{status}: {checked} notes checked, {len(errors)} error(s), {len(warnings)} warning(s)")
    return 1 if errors else 0


# ---- stats ------------------------------------------------------------------

def _count(directory: Path, predicate, recursive: bool = False) -> int:
    if not directory.is_dir():
        return 0
    return sum(
        1
        for p in vault_mod.iter_note_paths(directory, recursive=recursive)
        if predicate(frontmatter.parse_frontmatter(p))
    )


def cmd_stats(args: argparse.Namespace) -> int:
    vault = Path(vault_mod.resolve_vault())
    areas = _count(vault / "areas", lambda fm: True)
    open_deferred = _count(
        vault / "deferred",
        lambda fm: fm.get("status") in ("open", "resurfaced"),
        recursive=True,
    )
    active_lessons = _count(
        vault / "lessons",
        lambda fm: fm.get("status", "active") == "active",
        recursive=True,
    )
    dead_ends = _count(
        vault / "dead-ends", lambda fm: fm.get("type") == "dead-end", recursive=True
    )
    sessions = _count(vault / "sessions", lambda fm: fm.get("type") == "session", recursive=True)

    print(f"vault: {vault}")
    print(f"areas:          {areas}")
    print(f"open deferred:  {open_deferred}")
    print(f"active lessons: {active_lessons}")
    print(f"dead-ends:      {dead_ends}")
    print(f"sessions:       {sessions}")
    return 0


# ---- session-note -----------------------------------------------------------

def _session_id_from_args_or_env(args: argparse.Namespace) -> str:
    """Resolve the session id: explicit ``--session-id`` flag wins, else the
    Claude Code env var (``CLAUDE_CODE_SESSION_ID``, with the legacy
    ``CLAUDE_SESSION_ID`` name as a fallback)."""
    sid = getattr(args, "session_id", None)
    if sid:
        return sid
    return (
        os.environ.get("CLAUDE_CODE_SESSION_ID")
        or os.environ.get("CLAUDE_SESSION_ID")
        or ""
    )


def cmd_session_note(args: argparse.Namespace) -> int:
    """Print the vault-relative path of the session note for this session.

    Resolution order (see `vault.resolve_session_note`): exact session-id
    frontmatter match (cwd-independent) → worktree-name fallback (newest by
    filename timestamp). On a miss, prints a diagnostic listing what was tried
    to stderr and exits 1, so callers don't invent exploratory `ls`/`git`
    commands to guess.
    """
    vault = Path(vault_mod.resolve_vault())
    session_id = _session_id_from_args_or_env(args)
    worktree_name = args.worktree or vault_mod.detect_worktree_name()

    note = vault_mod.resolve_session_note(
        vault, session_id=session_id, worktree_name=worktree_name
    )
    if note is not None:
        try:
            print(note.relative_to(vault))
        except ValueError:
            print(note)
        return 0

    print(
        "lore session-note: no session note resolved.\n"
        f"  session_id: {session_id or '<unset>'}\n"
        f"  worktree:   {worktree_name or '<unknown>'}\n"
        f"  searched:   {vault / 'sessions'}",
        file=sys.stderr,
    )
    return 1


# ---- link-server ------------------------------------------------------------

LINK_SERVER_LABEL = "com.lore.link-server"
_DEFAULT_LINK_PORT = 7777
_LINK_SERVER_PYTHON = "/usr/bin/python3"
_LINK_OUT_LOG = "/tmp/lore-link-server.out.log"
_LINK_ERR_LOG = "/tmp/lore-link-server.err.log"


def _link_server_port() -> int:
    """Resolve the link-server port — $LORE_LINK_PORT (valid int) else 7777.

    Mirrors lore-link-server's resolve_port() convention.
    """
    raw = os.environ.get("LORE_LINK_PORT", "").strip()
    if not raw:
        return _DEFAULT_LINK_PORT
    try:
        return int(raw)
    except ValueError:
        return _DEFAULT_LINK_PORT


def _link_server_guards_ok() -> tuple[bool, str]:
    """Verify darwin + `open` + Obsidian presence.

    Returns (ok, message). On failure the message is actionable and the caller
    refuses the install without writing anything.
    """
    if sys.platform != "darwin":
        return False, (
            f"link-server: requires macOS (darwin); current platform is {sys.platform!r}"
        )
    if shutil.which("open") is None:
        return False, "link-server: `open` not found in PATH; cannot open Obsidian URIs"
    if not Path("/Applications/Obsidian.app").exists():
        return False, (
            "link-server: Obsidian not found at /Applications/Obsidian.app — "
            "install Obsidian before installing the link-server"
        )
    return True, ""


def _agent_running(label: str) -> bool:
    """True iff `launchctl list` shows the agent label."""
    result = subprocess.run(
        ["launchctl", "list"], capture_output=True, text=True, check=False
    )
    if result.returncode != 0:
        return False
    return any(label in line for line in result.stdout.splitlines())


def _link_server_install(args: argparse.Namespace) -> int:
    port = _link_server_port()

    # (a) port-in-use precheck FIRST — refuse before writing anything.
    if link_server.port_in_use(port):
        # A legacy per-user agent on the same port is the usual culprit; let the
        # operator name it via $LORE_LINK_OLD_AGENT so the message stays
        # actionable without baking a machine-specific label into the source.
        old_agent = os.environ.get("LORE_LINK_OLD_AGENT", "").strip()
        culprit = (
            f"a previously-loaded launchd agent ({old_agent})"
            if old_agent
            else "another process (e.g. a legacy link-server launchd agent)"
        )
        unload_hint = (
            f"\n  launchctl unload -w ~/Library/LaunchAgents/{old_agent}.plist"
            if old_agent
            else "\n  launchctl list   # find what holds the port, then unload it"
        )
        print(
            f"link-server: port {port} in use — likely {culprit} still holding it. Run:"
            f"{unload_hint}\n"
            "then re-run `lore link-server install`.",
            file=sys.stderr,
        )
        return 1

    # (b) darwin + open + Obsidian guards — hard refuse, no partial install.
    ok, msg = _link_server_guards_ok()
    if not ok:
        print(msg, file=sys.stderr)
        return 1

    vault = vault_mod.resolve_vault()
    plugin_root = str(PLUGIN_ROOT)
    server_script = str(PLUGIN_ROOT / "bin" / "lore-link-server")

    launch_agents_dir = Path(args.launch_agents_dir).expanduser()
    state_dir = Path(args.state_dir).expanduser()
    plist_path = launch_agents_dir / f"{LINK_SERVER_LABEL}.plist"

    existing = link_server.read_state(state_dir)
    if existing and existing.get("vault") == vault and existing.get("port") == port:
        print(f"link-server: already installed (vault {vault}, port {port}); nothing to do.")
        return 0

    # (c) render + write plist, then load it.
    xml = link_server.render_plist(
        label=LINK_SERVER_LABEL,
        python=_LINK_SERVER_PYTHON,
        server_script=server_script,
        vault=vault,
        port=port,
        out_log=_LINK_OUT_LOG,
        err_log=_LINK_ERR_LOG,
    )
    launch_agents_dir.mkdir(parents=True, exist_ok=True)
    plist_path.write_text(xml)

    # A changed-config re-run must drop the old agent before loading the new one.
    if existing:
        subprocess.run(
            ["launchctl", "unload", "-w", str(plist_path)],
            capture_output=True, text=True, check=False,
        )
    load = subprocess.run(
        ["launchctl", "load", "-w", str(plist_path)],
        capture_output=True, text=True, check=False,
    )
    if load.returncode != 0:
        print(
            f"link-server: launchctl load failed: {load.stderr.strip()}",
            file=sys.stderr,
        )
        return 1

    # (d) write state ONLY after a successful load.
    link_server.write_state(state_dir, {
        "schema": link_server.STATE_SCHEMA,
        "port": port,
        "plist_path": str(plist_path),
        "vault": vault,
        "plugin_root": plugin_root,
    })
    print(f"link-server: installed and loaded ({LINK_SERVER_LABEL}, vault {vault}, port {port}).")
    return 0


def _link_server_uninstall(args: argparse.Namespace) -> int:
    state_dir = Path(args.state_dir).expanduser()
    launch_agents_dir = Path(args.launch_agents_dir).expanduser()

    state = link_server.read_state(state_dir)
    plist_path = (
        Path(state["plist_path"])
        if state and state.get("plist_path")
        else launch_agents_dir / f"{LINK_SERVER_LABEL}.plist"
    )

    if plist_path.exists():
        subprocess.run(
            ["launchctl", "unload", "-w", str(plist_path)],
            capture_output=True, text=True, check=False,
        )
        plist_path.unlink()

    link_server.clear_state(state_dir)
    print("link-server: uninstalled.")
    return 0


def _link_server_status(args: argparse.Namespace) -> int:
    state_dir = Path(args.state_dir).expanduser()
    state = link_server.read_state(state_dir)

    if state is None:
        # No trustworthy state — fall back to the env-resolved port for the hint.
        print(f"link-server: not installed (resolved port {_link_server_port()}, no state file).")
        return 0

    # Prefer the installed port from state; $LORE_LINK_PORT in the current shell
    # may differ from what the agent was actually installed with.
    port = state.get("port", _link_server_port())
    print(f"link-server: installed port {port}")
    print(f"  state: {link_server.state_path(state_dir)}")
    for key in ("schema", "port", "plist_path", "vault", "plugin_root"):
        print(f"    {key}: {state.get(key)}")

    current_root = str(PLUGIN_ROOT)
    if state.get("plugin_root") != current_root:
        print(
            f"link-server: STALE — state plugin_root {state.get('plugin_root')!r} "
            f"!= current {current_root!r}; reinstall with `lore link-server install`.",
            file=sys.stderr,
        )
        return 1

    if not _agent_running(LINK_SERVER_LABEL):
        print(
            f"link-server: WARNING — state file present but agent {LINK_SERVER_LABEL} "
            "is NOT running; reinstall with `lore link-server install`.",
            file=sys.stderr,
        )
        return 1

    print("link-server: running.")
    return 0


def cmd_link_server(args: argparse.Namespace) -> int:
    if args.action == "install":
        return _link_server_install(args)
    if args.action == "uninstall":
        return _link_server_uninstall(args)
    return _link_server_status(args)


# ---- argparse ---------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="lore", description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)

    p_init = sub.add_parser("init", help="Scaffold a new vault")
    p_init.add_argument("path")
    p_init.add_argument("--force", action="store_true", help="Scaffold into a non-empty dir")
    p_init.add_argument("--allow-outside-home", action="store_true", help="Allow a target outside $HOME")
    p_init.add_argument("--yes", action="store_true", help="Skip the confirmation prompt")
    p_init.set_defaults(func=cmd_init)

    p_patch = sub.add_parser("patch", help="Append text under a section")
    p_patch.add_argument("file")
    p_patch.add_argument("section")
    p_patch.add_argument("--text", default=None, help="Text to append (else read stdin)")
    p_patch.set_defaults(func=cmd_patch)

    p_status = sub.add_parser("set-status", help="Validate + set a note's status")
    p_status.add_argument("file")
    p_status.add_argument("value")
    p_status.set_defaults(func=cmd_set_status)

    p_stats = sub.add_parser("stats", help="Print counts for the resolved vault")
    p_stats.set_defaults(func=cmd_stats)

    p_link = sub.add_parser(
        "link-server",
        help="Manage the localhost Obsidian link bridge launchd agent",
    )
    p_link.add_argument(
        "action",
        choices=["install", "uninstall", "status"],
        help="install / uninstall / status of the com.lore.link-server agent",
    )
    p_link.add_argument(
        "--launch-agents-dir",
        dest="launch_agents_dir",
        default="~/Library/LaunchAgents",
        help="Directory to write the launchd plist into (default: ~/Library/LaunchAgents)",
    )
    p_link.add_argument(
        "--state-dir",
        dest="state_dir",
        default="~/.config/lore",
        help="Directory for the install-state file (default: ~/.config/lore)",
    )
    p_link.set_defaults(func=cmd_link_server)

    p_session_note = sub.add_parser(
        "session-note",
        help="Print the session note path for this session (id-first, worktree fallback)",
    )
    p_session_note.add_argument(
        "--session-id",
        dest="session_id",
        default=None,
        help="Session id to resolve (default: $CLAUDE_CODE_SESSION_ID)",
    )
    p_session_note.add_argument(
        "--worktree",
        default=None,
        help="Worktree name for the fallback (default: auto-detected)",
    )
    p_session_note.set_defaults(func=cmd_session_note)

    p_sync = sub.add_parser("sync", help="Stage, commit, and push the vault")
    p_sync.add_argument(
        "--message", "-m", default=None,
        help=f"Commit message (default: {DEFAULT_SYNC_MSG!r})",
    )
    p_sync.set_defaults(func=cmd_sync)

    p_new = sub.add_parser("new", help="Render a template and write a new vault note")
    p_new.add_argument("type", choices=list(_NOTE_DIRS), help="Note type to create")
    p_new.add_argument("--title", required=True, help="Title for the note (used in slug)")
    p_new.add_argument("--vault", default=None, help="Vault path (overrides $LORE_VAULT)")
    p_new.add_argument("--project", default=None, help="Project name to stamp in frontmatter")
    # deferred
    p_new.add_argument("--surfaces", default=None, help="CSV area names this item surfaces on (deferred)")
    p_new.add_argument("--next-check", dest="next_check", default=None, help="When to next check (deferred)")
    p_new.add_argument("--revisit-after", dest="revisit_after", default=None, help="Date-bound revisit trigger (deferred)")
    # dead-end
    p_new.add_argument("--areas", default=None, help="CSV area names (dead-end, decision)")
    p_new.add_argument("--tried", default=None, help="Date the approach was tried (dead-end; defaults to today)")
    p_new.add_argument("--revive-condition", dest="revive_condition", default=None, help="Condition to retry (dead-end)")
    # radar
    p_new.add_argument("--source", default=None, help="Where updates appear (radar)")
    p_new.add_argument("--target", default=None, help="Version or state being waited for (radar)")
    p_new.add_argument("--check", default=None, help="Check cadence (radar)")
    # area
    p_new.add_argument("--keywords", default=None, help="CSV keywords for branch-based recall (area)")
    p_new.add_argument("--key-files", dest="key_files", default=None, help="CSV key file paths (area)")
    # plan
    p_new.add_argument("--related-areas", dest="related_areas", default=None, help="CSV area names (plan)")
    p_new.add_argument("--related-spec", dest="related_spec", default=None, help="Related spec path or wikilink (plan)")
    p_new.set_defaults(func=cmd_new)

    p_seed = sub.add_parser(
        "seed",
        help="Scaffold an inbox capture (named <name>) and open it in Obsidian",
    )
    p_seed.add_argument("name", help="Human-readable name; slugified for the filename")
    p_seed.add_argument("--vault", default=None, help="Vault path (overrides $LORE_VAULT)")
    p_seed.add_argument("--no-open", dest="no_open", action="store_true", help="Create the note but don't open Obsidian")
    p_seed.set_defaults(func=cmd_seed)

    def _add_session_selectors(p: argparse.ArgumentParser) -> None:
        """Shared overrides for the auto-detected session note."""
        p.add_argument(
            "--session-id", dest="session_id", default=None,
            help="Session id to target (default: $CLAUDE_CODE_SESSION_ID)",
        )
        p.add_argument(
            "--worktree", default=None,
            help="Worktree name for the fallback (default: auto-detected)",
        )

    p_finish = sub.add_parser(
        "finish",
        help="Finalize the active session note for this worktree",
    )
    _add_session_selectors(p_finish)
    p_finish.set_defaults(func=cmd_finish)

    p_handoff = sub.add_parser(
        "handoff",
        help="Shelve the active session note for this worktree (for pickup later)",
    )
    _add_session_selectors(p_handoff)
    p_handoff.add_argument(
        "--pickup-hints-file",
        dest="pickup_hints_file",
        default=None,
        metavar="PATH",
        help="File whose content is written under '## Pickup hints' before shelving",
    )
    p_handoff.set_defaults(func=cmd_handoff)

    p_shelved = sub.add_parser(
        "shelved",
        help="List shelved/handoff session notes (most-recent-first) for pickup",
    )
    p_shelved.add_argument(
        "--slug",
        default=None,
        help="Narrow to one worktree slug",
    )
    p_shelved.set_defaults(func=cmd_shelved)

    p_resume = sub.add_parser(
        "resume",
        help="Flip a shelved/handoff session note back to active",
    )
    p_resume.add_argument(
        "target",
        nargs="?",
        default=None,
        help="Session note path OR worktree slug to resume "
             "(omit to resume the current session's shelved note)",
    )
    _add_session_selectors(p_resume)
    p_resume.set_defaults(func=cmd_resume)

    p_review = sub.add_parser(
        "review",
        help="Generate a vault migration-discipline report",
    )
    p_review.add_argument(
        "--since",
        default=None,
        help="Lookback window for activity section (e.g. 7d, 2026-04-01). "
             "Default: since the most recent review note, or 7 days ago.",
    )
    p_review.set_defaults(func=cmd_review)

    p_validate = sub.add_parser(
        "validate",
        help="Validate vault frontmatter against the canonical schema",
    )
    p_validate.add_argument(
        "--strict",
        action="store_true",
        help="Also warn on unknown (non-schema) fields, not just known drift.",
    )
    p_validate.set_defaults(func=cmd_validate)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
